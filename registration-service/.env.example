# Registration Service — Environment Variables
# Copy to .env and fill in values

DB_URL=jdbc:postgresql://<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# Inter-service URLs (defaults are Docker Compose service names)
# For local dev WITHOUT Docker, change to:
#   USER_SERVICE_URL=http://localhost:8001
#   EVENT_SERVICE_URL=http://localhost:8002
#   NOTIFICATION_SERVICE_URL=http://localhost:8004
USER_SERVICE_URL=http://user-service:8001
EVENT_SERVICE_URL=http://event-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8004

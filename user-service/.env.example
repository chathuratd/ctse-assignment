# ─────────────────────────────────────────────────────────────────────────────
# User Service — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. .env is in .gitignore — NEVER commit the actual .env file
#
# GENERATING A JWT SECRET:
#   openssl rand -base64 32

# PostgreSQL Database (Supabase)
DB_URL=jdbc:postgresql://<your-project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your-base64-encoded-secret-key-minimum-32-bytes
